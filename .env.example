# ─── Supabase ────────────────────────────────────────────────────────────────
# Required — get from Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — needed for admin/service-role operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Optional — enables real AI portfolio analysis (falls back to demo if missing)
OPENAI_API_KEY=

# ─── External Market Data APIs ───────────────────────────────────────────────
# All optional — app falls back to Supabase data, then demo data
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=
COINGECKO_API_KEY=
BINANCE_API_KEY=

# ─── Market Sync ─────────────────────────────────────────────────────────────
# Secret header value for POST /api/market/sync
# Required in production — endpoint returns 403 without it
MARKET_SYNC_SECRET=

# ─── Cron ────────────────────────────────────────────────────────────────────
# Secret for GET /api/cron/market-refresh?secret=... (Vercel Cron or external)
CRON_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
# Optional — used for auth redirects and meta
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Архитектор Капитала
